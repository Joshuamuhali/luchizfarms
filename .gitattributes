# Image files - track with Git LFS
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
# All files in assets directories
src/assets/** filter=lfs diff=lfs merge=lfs -text
src/assets/**/*.jpg filter=lfs diff=lfs merge=lfs -text
src/assets/**/*.png filter=lfs diff=lfs merge=lfs -text
src/assets/3u[[:space:]]Export[[:space:]]Photos/*.JPG filter=lfs diff=lfs merge=lfs -text
src/assets/3u[[:space:]]Export[[:space:]]Photos/*.PNG filter=lfs diff=lfs merge=lfs -text
src/assets/farm-photos/*.JPG filter=lfs diff=lfs merge=lfs -text
src/assets/farm-photos/*.PNG filter=lfs diff=lfs merge=lfs -text
src/assets/*.jpg filter=lfs diff=lfs merge=lfs -text
src/assets/*.png filter=lfs diff=lfs merge=lfs -text
